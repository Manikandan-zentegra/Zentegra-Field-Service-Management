		map Map_view
		{
			displayName = "Map"
			show all rows from Admin    
			(
				Customer_Phone as "Customer Phone"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Customer_Name  as "Customer Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Customer_Email as "Customer Email"
				Service_Address  as "Service Address"
	 			(
	      			enable = Link_to_Map,Show_As_Decimal_Coordinates
	 			)
				Service_Name as "Service Name"
				Description
				Fault
				Prefer_Date as "Prefer Date"
				Prefer_Time as "Prefer Time"
				Service_Priority_By_Customer as "Service Priority By Customer"
				Language_Prefer_By_Customer as "Language Prefer By Customer"
				Service_Approved as "Service Approved"
				Latitude_And_Longitude as "Latitude And Longitude"
				Service_By_Organization as "Service By Organization"
				Service_Specialist_Name  as "Service Specialist Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Service_Specialist_Phone_Number as "Service Specialist Phone Number"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Employee_Email as "Employee Email"
				Language_Known as "Language Known"
				Service_Appointment as "Service Appointment "
				Added_User as "Added User"
			)
			options
			(
	 			display field = Service_Address
	 	 		radius = 100 Miles
	 		)
			conditional formatting
			(
				"New Formatting"
				{
				condition = (Latitude_And_Longitude is not null)
				fields = [Service_Address]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting"
				{
				condition = (Latitude_And_Longitude is not null)
				fields = [Service_Address]
				format = ""
				}
			)
		}
