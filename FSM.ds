											disable Service_ID;
										disable Name;
										disable Email;
										disable Service_ID;
										hide Service_man_phone_number;
						)
					}
				}

			}
			Disable1 as "Disable"
			{
				type =  form
				form = Cancel_Request

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Customer_Name;
										disable Customer_Email;
										disable Service_Address;
										hide Employee_Email;
										hide Admin_Mail;
						)
					}
				}

			}
			Disable2 as "Disable"
			{
				type =  form
				form = Field_Technician

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Customer_Email;
										disable Customer_Name;
										disable Service_ID;
