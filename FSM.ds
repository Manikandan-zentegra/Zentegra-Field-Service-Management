											// 2. Clean the Mobile Number
											rawNum = ifnull(input.Service_Specialist_Phone_Number,"").toString();
											cleanNumber = rawNum.replaceAll("[^0-9]","");
											// Take last 10 digits
											if(cleanNumber.length() > 10)
											{
												cleanNumber = cleanNumber.subString(cleanNumber.length() - 10);
											}
											// 3. Construct the final URL
											whatsappURL = "https://api.whatsapp.com/send?phone=91" + cleanNumber + "&text=" + encodedMsg;
											// 4. THE FINAL ACTION: Open WhatsApp immediately
											// This replaces 'show' and works perfectly in On Success
											openurl(whatsappURL,"new window");
											msgmail1 = "<b>Dear Customer,</b>" + "<br><br>Your Low - priority service" + " " + input.Service_By_Organization_Selected + " " + "was Cancelled !" + " " + "<br> Thank you for your cooperation." + "<br><br><b>Regards,</b>" + "<br>Admin from the Organization";
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Customer_Email
												reply to :"manikandan@zentegra.com"
												subject :"Low priority service cancelled by customer."
												message :msgmail1
											]
											msgmail2 = "<b>Admin,</b>" + "<br><br>Low - priority service was Cancelled by Customer!" + " " + "<br><br><b>Customer Name:</b>" + " " + input.Customer_Name + " " + "<br><b>Customer Phone Number:</b> " + input.Customer_Phone_Number + " " + "<br><b>Service selcted by customer:</b>" + input.Service_By_Organization_Selected + " " + "<br><b>Service ID:</b>" + input.Service_Order_ID + "<br><br><b>Regards,</b>" + "<br>The order has been cancelled by the customer. Kindly reach out to the customer if further clarification is required.";
											//send mail to the admin
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Admin_Mail
												reply to :"manikandan@zentegra.com"
												subject :"Your High priority order approved by Admin."
												message :msgmail2
											]
										}
						)
					}
				}

			}
