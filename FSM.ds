											msglow = "*I want to cancel my service request*" + "\n" + "\n*Customer Name:* " + input.Customer_Name + "\n*Customer Mobile:* " + input.Customer_Phone_Number + "\n*Service Address:* " + input.Service_Address + "\n*Service Priority:* " + input.Service_Priority + "\n*Email Address:* " + input.Customer_Email + "\n*Service Name:* " + input.Service_By_Organization_Selected + "\n*Reason:* " + input.Reason + "\n*Fault:* " + input.Fault + "\n*Prefer Date:* " + input.Prefered_Date + "\n*Prefer Time:* " + input.Prefered_Time + "\n*Language:* " + input.Prefered_Language_For_Service + "\n*Above Information Are Correct:* " + input.Above_Information_Are_Correct + "\n*Service Order ID:* " + input.Service_Order_ID;
