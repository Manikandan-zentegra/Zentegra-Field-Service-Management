		page test
		{
			displayname = "test"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet()\ncontent\n&lt;%{\n\t%&gt;\n&lt;!DOCTYPE html&gt;\n&lt;html lang=&quot;en&quot;&gt;\n&lt;head&gt;\n&lt;meta charset=&quot;UTF-8&quot;&gt;\n&lt;title&gt;Dashboard&lt;/title&gt;\n\n&lt;style&gt;\nbody {\n    margin: 0;\n    font-family: Arial, sans-serif;\n    background: #eef1f5;\n}\n\n/* Header */\n.header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 15px 30px;\n    background: #eef1f5;\n}\n\n.header h3 {\n    margin: 0;\n    font-weight: normal;\n}\n\n/* Dropdown */\n.dropdown {\n    border: 1px solid #4caf50;\n    padding: 8px 12px;\n    border-radius: 6px;\n    background: #fff;\n    font-size: 14px;\n}\n\n/* Cards Row */\n.cards {\n    display: flex;\n    gap: 20px;\n    padding: 0 30px;\n}\n\n.card {\n    background: #fff;\n    flex: 1;\n    padding: 20px;\n    border-radius: 10px;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.05);\n}\n\n.card h4 {\n    margin: 0 0 10px;\n    font-weight: normal;\n}\n\n.card .number {\n    font-size: 30px;\n    font-weight: bold;\n}\n\n.card .sub {\n    margin-top: 20px;\n    font-size: 13px;\n    color: #777;\n}\n\n/* Sections */\n.section {\n    display: flex;\n    gap: 20px;\n    padding: 20px 30px;\n}\n\n.box {\n    flex: 1;\n    background: #fff;\n    border-radius: 10px;\n    padding: 15px;\n    min-height: 250px;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.05);\n}\n\n.box h4 {\n    margin: 0 0 15px;\n    font-weight: normal;\n}\n\n.empty {\n    text-align: center;\n    color: #aaa;\n    margin-top: 80px;\n    font-size: 14px;\n}\n\n/* Footer sections */\n.section-bottom {\n    display: flex;\n    gap: 20px;\n    padding: 0 30px 30px;\n}\n\n&lt;/style&gt;\n&lt;/head&gt;\n\n&lt;body&gt;\n\n&lt;!-- Header --&gt;\n&lt;div class=&quot;header&quot;&gt;\n    &lt;h3&gt;Welcome &lt;b&gt;&lt;/b&gt;&lt;/h3&gt;\n    &lt;div class=&quot;dropdown&quot;&gt;Technician View \u25BC&lt;/div&gt;\n&lt;/div&gt;\n\n&lt;!-- Top Cards --&gt;\n&lt;div class=&quot;cards&quot;&gt;\n\n    &lt;div class=&quot;card&quot;&gt;\n        &lt;h4&gt;Upcoming Service Appointments&lt;/h4&gt;\n        &lt;div class=&quot;number&quot;&gt;0&lt;/div&gt;\n        &lt;div class=&quot;sub&quot;&gt;Last 6 Months&lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;card&quot;&gt;\n        &lt;h4&gt;In Progress Service Appointments&lt;/h4&gt;\n        &lt;div class=&quot;number&quot;&gt;0&lt;/div&gt;\n        &lt;div class=&quot;sub&quot;&gt;This Month&lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;card&quot;&gt;\n        &lt;h4&gt;Completed Service Appointments&lt;/h4&gt;\n        &lt;div class=&quot;number&quot;&gt;0&lt;/div&gt;\n        &lt;div class=&quot;sub&quot;&gt;This Month&lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;card&quot;&gt;\n        &lt;h4&gt;Total Trips&lt;/h4&gt;\n        &lt;div class=&quot;number&quot;&gt;0&lt;/div&gt;\n        &lt;div class=&quot;sub&quot;&gt;Last Month 0&lt;/div&gt;\n    &lt;/div&gt;\n\n&lt;/div&gt;\n\n&lt;!-- Middle Section --&gt;\n&lt;div class=&quot;section&quot;&gt;\n\n    &lt;div class=&quot;box&quot;&gt;\n        &lt;h4&gt;My Dispatched Service Appointments&lt;/h4&gt;\n        &lt;div class=&quot;empty&quot;&gt;No Records Found&lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;box&quot;&gt;\n        &lt;h4&gt;My In Progress Service Appointments&lt;/h4&gt;\n        &lt;div class=&quot;empty&quot;&gt;No Records Found&lt;/div&gt;\n    &lt;/div&gt;\n\n&lt;/div&gt;\n\n&lt;!-- Bottom Section --&gt;\n&lt;div class=&quot;section-bottom&quot;&gt;\n\n    &lt;div class=&quot;box&quot;&gt;\n        &lt;h4&gt;My Completed Service Appointments&lt;/h4&gt;\n        &lt;div class=&quot;empty&quot;&gt;No Records Found&lt;/div&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;box&quot;&gt;\n        &lt;h4&gt;My Cancelled Service Appointments&lt;/h4&gt;\n        &lt;div class=&quot;empty&quot;&gt;No Records Found&lt;/div&gt;\n    &lt;/div&gt;\n\n&lt;/div&gt;\n\n&lt;/body&gt;\n&lt;/html&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Home
