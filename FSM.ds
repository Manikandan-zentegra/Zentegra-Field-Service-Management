			Rules as "Rules"
			{
				type =  form
				form = Customer_Request

				record event = on add or edit

				on user input of Prefer_Date
				{
					actions 
					{
						custom deluge script
						(
											if(input.Prefer_Date < zoho.currentdate)
										{
											alert "Past date not allowded to service.";
											input.Prefer_Date = null;
										}
						)
					}
				}

			}
			Disable_fields as "Disable fields"
			{
				type =  form
				form = Reschedule_My_Service

