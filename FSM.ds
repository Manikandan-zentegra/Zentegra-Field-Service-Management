		page Dispatch_Console
		{
			displayname = "Dispatch Console"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='50%'\n   \t>\n\t<report \n\telementName='Report'\n\n\t\tappLinkName = 'thisapp'\n\t\tlinkName = 'All_Customer_Requests'\n\t\n\t\tiszreport = 'false'\n\theightType = 'auto'\n\theightValue = '700'\n\n/>\n</column><column\n   \t\t width='50%'\n   \t>\n\t<report \n\telementName='Report 1'\n\n\t\tappLinkName = 'thisapp'\n\t\tlinkName = 'Calender'\n\t\n\t\tiszreport = 'false'\n\theightType = 'auto'\n\theightValue = '700'\n\n/>\n</column>\n</row>\n</layout>\n</zml>"
		}
	}


		workflow
		{
		form
		{
			Send_Email_Form_Propertie as "Send Email - Form Properties"
			{
				type =  presuccess
				form = Add_Organization
				on start
				{
					actions 
					{
						sendmail
						(
							from : "zoho.adminuserid"
							to : "zoho.adminuserid"
							subject : "FSM : New entry added"
							message : "Hello,<br/><br/>A new entry added in 'Add Organization' form of 'FSM' application.<br/>"
							attachments : template : _default as inline
						)
					}
				}
			}
			Fetch_The_Customer_Data_F as "Fetch The Customer Data From Customer Form"
			{
				type =  form
				form = Admin

				record event = on add or edit

				on user input of Customer_Phone
				{
					actions 
					{
						custom deluge script
						(
											fetch_cust = Customer_Request[Phone_Number == input.Customer_Phone];
										info fetch_cust;
										if(fetch_cust.count() > 0)
										{
											input.Customer_Name = fetch_cust.Name;
											input.Customer_Email = fetch_cust.Email;
											input.Service_Address = fetch_cust.Service_Address;
											input.Service_Name = fetch_cust.Service_By_Organization.Name_Of_The_Service;
											input.Description = fetch_cust.Additional_Instructions;
											input.Fault = fetch_cust.Fault;
											input.Prefer_Time = fetch_cust.Prefer_Time;
											input.Service_Priority_By_Customer = fetch_cust.Service_Priority;
											input.Prefer_Date = fetch_cust.Prefer_Date;
											input.Language_Prefer_By_Customer = fetch_cust.Prefered_Language_For_Service;
											response = zoho.map.geoCode(input.Service_Address.toString());
											input.Latitude_And_Longitude = response;
											info response;
										}
										else
										{
											input.Customer_Name = null;
										}
						)
					}
				}

			}
			Company_Started_Date_Rule as "Company Started Date Rules"
			{
				type =  form
				form = Add_Organization

				record event = on add or edit

				on user input of Company_Started_Date
				{
					actions 
					{
						custom deluge script
						(
											if(input.Company_Started_Date > zoho.currentdate)
										{
											input.Company_Started_Date = null;
											alert "Future date not allowded in company started date.";
											success message "Thanks for your feedback";
										}
						)
					}
				}

			}
			Date_Of_Joining_Rules as "Date Of Joining Rules"
			{
				type =  form
				form = Add_Technician

				record event = on add or edit

				on user input of Date_Of_Joining
				{
					actions 
					{
						custom deluge script
						(
											if(input.Date_Of_Joining > zoho.currentdate)
										{
											input.Date_Of_Joining = null;
											alert "Future date not allowded in date of joining.";
										}
						)
					}
				}

			}
			Generate_Employee_ID as "Generate Employee ID"
			{
				type =  form
				form = Add_Technician

				record event = on add or edit

				on user input of Phone_Number
				{
					actions 
					{
						custom deluge script
						(
											// 1. Get the name part of the email
										zip_code = Add_Organization[Company_Address.postal_Code != null];
										code = zip_code.Company_Address.postal_Code;
										if(input.Phone_Number != null && zip_code != null)
										{
											phpart = input.Phone_Number.getsuffix("+91");
											// 3. Combine them
											input.Employee_ID = "EMP-" + code + phpart;
										}
										else
										{
											input.Employee_ID = null;
										}
						)
					}
				}

			}
			Calculate_Price_With_Tax as "Calculate Price With Tax"
			{
				type =  form
				form = Service_By_Organization

				record event = on add or edit

				on user input of Tax_Percentage
				{
					actions 
					{
						custom deluge script
						(
											if(input.Price != null && input.Tax_Percentage != null)
										{
											price = input.Price;
											tax = input.Tax_Percentage;
											tax_per = tax / 100;
											mul = tax_per * price;
											input.Total_Amount = mul + input.Price;
										}
										else
										{
											input.Total_Amount = null;
										}
						)
					}
				}

			}
			Generate_Order_ID as "Generate Order ID"
			{
				type =  form
				form = Customer_Request

				record event = on add or edit

				on user input of Service_Priority
				{
					actions 
					{
						custom deluge script
						(
											// 1. Get the name part of the email
										if(input.Phone_Number != null)
										{
											if(input.Service_Priority == "High")
											{
												zip_code = input.Service_Address.postal_Code;
												phpart = input.Phone_Number.getsuffix("+91");
												word = input.Service_Priority.getprefix("i");
												// 3. Combine them
												input.Service_ID = "S-" + word + reverse(zip_code + phpart);
											}
											else if(input.Service_Priority == "Low")
											{
												zip_code = input.Service_Address.postal_Code;
												phpart = input.Phone_Number.getsuffix("+91");
												word1 = input.Service_Priority.getprefix("o");
												// 3. Combine them
												input.Service_ID = "S-" + word1 + reverse(zip_code + phpart);
											}
											else
											{
												input.Service_ID = null;
											}
										}
										else
										{
											input.Service_ID = null;
										}
						)
					}
				}

			}
			Whatsapp_Integration as "Whatsapp Integration"
			{
				type =  form
				form = Customer_Request

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Service_Priority == "High")
										{
											// 1. Construct the Message (Same as your code)
											msg = "High Priority Service" + "\n" + "Customer Name: " + ifnull(input.Name,"Guest") + "\n" + "Phone number: " + ifnull(input.Phone_Number,"Phone Number") + "\n" + "Customer Address: " + ifnull(input.Service_Address,"Address not provided") + "\n" + "Prefer date: " + ifnull(input.Prefer_Date,"Date not set") + "\n" + "Prefer time: " + ifnull(input.Prefer_Time,"Time not set") + "\n" + "Service: " + ifnull(input.Service_By_Organization,"Service not selected") + "\n" + "Fault: " + ifnull(input.Fault,"No fault described") + "\n" + "Service priority :" + ifnull(input.Service_Priority,"Not selected service priority") + "\n" + "language preference for services :" + ifnull(input.Prefered_Language_For_Service,"no preference") + "\n" + "Additional Instruction :" + ifnull(input.Additional_Instructions,"No additional informations") + "\n" + "service ID :" + ifnull(input.Service_ID,"no service ID");
											// + fileLink;
											// FIX: Must use zoho.encryption.urlEncode
											encodedMsg = zoho.encryption.urlEncode(msg);
											// 2. FETCHING CODE (Without using first())
											// admin_ph_num is now a Collection (a list of all records found)
											admin_ph_num_collection = Add_Organization[Admin_Phone_Number != null];
											// We use 'for each' to step inside the collection and get the actual data
											for each  admin_record in admin_ph_num_collection
											{
												// Extract the field from the specific record inside the loop
												rawNum = admin_record.Admin_Phone_Number.toString();
												// Clean the Mobile Number
												cleanNumber = rawNum.replaceAll("[^0-9]","");
												// Take last 10 digits
												if(cleanNumber.length() >= 10)
												{
													cleanNumber = cleanNumber.substring(cleanNumber.length() - 10);
												}
												// 3. Construct the final URL
												whatsappURL = "https://api.whatsapp.com/send?phone=91" + cleanNumber + "&text=" + encodedMsg;
												// 4. THE FINAL ACTION
												openurl(whatsappURL,"new window");
											}
										}
										else if(input.Service_Priority == "Low")
										{
											msg = "High Priority Service" + "\n" + "Customer Name: " + ifnull(input.Name,"Guest") + "\n" + "Phone number: " + ifnull(input.Phone_Number,"Phone Number") + "\n" + "Customer Address: " + ifnull(input.Service_Address,"Address not provided") + "\n" + "Prefer date: " + ifnull(input.Prefer_Date,"Date not set") + "\n" + "Prefer time: " + ifnull(input.Prefer_Time,"Time not set") + "\n" + "Service: " + ifnull(input.Service_By_Organization,"Service not selected") + "\n" + "Fault: " + ifnull(input.Fault,"No fault described") + "\n" + "Service priority :" + ifnull(input.Service_Priority,"Not selected service priority") + "\n" + "language preference for services :" + ifnull(input.Prefered_Language_For_Service,"no preference") + "\n" + "Additional Instruction :" + ifnull(input.Additional_Instructions,"No additional informations") + "\n" + "service ID :" + ifnull(input.Service_ID,"no service ID");
											fetch_admin_mail = Add_Organization[Confirm_Request == input.Confirm_Request];
											if(fetch_admin_mail.count() > 0)
											{
												input.Admin_Email = fetch_admin_mail.Admin_Email;
											}
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Admin_Email
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"New Low Priority Service: " + ifnull(input.Service_ID,"")
												message :msg
											]
										}
										else
										{
											// This executes if Service_Priority is NOT "Low"
											info "Priority not selected, Please select";
										}
										// info fetch_admin_mail;
						)
					}
				}

			}
