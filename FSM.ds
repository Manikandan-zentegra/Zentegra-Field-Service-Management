										disable Tax_Percentage;
										disable Tax_Amount;
										hide Organization_Name;
										hide Organization_Address;
										hide Organization_Phone;
										hide Organization_Website;
										hide Start_Date_Time;
										hide End_Date_Time;
						)
					}
				}

			}
			Hide_and_Disable as "Hide and Disable"
			{
				type =  form
				form = Admin

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Customer_Name;
										disable Customer_Email;
										disable Service_Address;
										hide Latitude_And_Longitude;
										hide Employee_Lati;
										disable Employee_Address;
										disable Employee_Email;
						)
					}
				}

			}
		}

		schedule
		{
			Send_Daily_Report as "Send Daily Report"
			{
				type =  schedule
				start = "2026-03-27 02:25:00"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						var = Add_Organization[Company_Name != null];
										if(var.count() > 0)
										{
											var1 = var.Payment_Types_Received_From_Organization && var.Company_Started_Date;
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :"manikandansjobzen@gmail.com"
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"Your Hotel Reservation Ticket - Hills Hotel"
												message :var1
											]
										}
					)
					}
				}
			}
		}




