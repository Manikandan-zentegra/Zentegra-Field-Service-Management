			Show_Estimation_Types as "Show Estimation Types"
			{
				type =  form
				form = Estimations

				record event = on add or edit

				on user input of Estimation_Type
				{
					actions 
					{
						custom deluge script
						(
											if(input.Estimation_Type == "Normal")
										{
											ticket_html = "";
											ticket_html = ticket_html + "<html>";
											ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Estimation</title></head>";
											ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
											ticket_html = ticket_html + "<table width='750' style='background:#ffffff;padding:40px;border:1px solid #ddd;'>";
											// --- TOP HEADER ---
											ticket_html = ticket_html + "<tr><td><table width='100%'><tr><td style='vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0;color:#000;font-size:20px;'>Estimation" + " " + "From" + " " + input.Organization_Name;
											ticket_html = ticket_html + "<h5 style='margin:0;color:#000;font-size:15px;font-weight:300;'>" + " " + "by" + " " + "Admin" + " " + input.Admin_Name + "</h5>";
											ticket_html = ticket_html + "<h6 style='margin:0;color:#000;font-size:15px;font-weight:300;'>" + " " + input.Organization_Address + "<h6>";
											ticket_html = ticket_html + "</td></tr></table>";
											// --- ADDRESS SECTION ---
											ticket_html = ticket_html + "<tr><td style='padding-top:40px;'><table width='100%'><tr><td width='50%' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Service Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#333;line-height:1.5;'>" + input.Customer_Address + "</p></td>";
											ticket_html = ticket_html + "<td width='50%' align='right' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Billing Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#333;line-height:1.5;'>" + input.Customer_Address + "<br>Zentegra<br>Bengaluru, Karnataka</p></td></tr></table></td></tr>";
											// --- SERVICE TABLE (Black Header Bar) ---
											ticket_html = ticket_html + "<tr><td style='padding-top:30px;'><table width='100%' cellspacing='0' style='border-collapse:collapse;'>";
											// The black box row - padding increased to 12px for better thickness
											ticket_html = ticket_html + "<tr style='background:#111;color:#fff;'>";
											ticket_html = ticket_html + "<th align='left' style='padding:12px 10px;font-size:12px;'>Service & Part</th>";
											ticket_html = ticket_html + "<th align='left' style='padding:12px 10px;font-size:12px;'>Tax (in %)</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:12px 10px;font-size:12px;'>Tax Amount</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:12px 10px;font-size:12px;'>Line Item Amount</th></tr>";
											// Item Data Row - Fixed to exactly 3 columns to match the header
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:15px 10px;font-size:13px;'><strong>" + input.Service_Name + "</strong></td>";
											ticket_html = ticket_html + "<td style='padding:15px 10px;font-size:13px;'><strong>" + input.Tax_Percentage + "</strong></td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 10px;font-size:13px;'>" + input.Tax_Amount + "</td>";
											// List price left blank as per template
											ticket_html = ticket_html + "<td align='right' style='padding:15px 10px;font-size:13px;'>" + input.Total_Price + "</td></tr>";
											// Bottom border after the items
											ticket_html = ticket_html + "<tr><td colspan='4' style='border-bottom:1px solid #000;'></td></tr></table></td></tr>";
											// --- TOTALS --- 
											ticket_html = ticket_html + "<tr><td align='right' style='padding-top:20px;'><table width='250' style='font-size:13px;line-height:2;'>";
											ticket_html = ticket_html + "<tr><td align='right' style='color:#555;'>Tax Total</td><td align='right' style='padding-left:20px;'>₹ " + input.Tax_Amount + "</td></tr>";
											ticket_html = ticket_html + "<tr><td align='right' style='font-weight:bold;'>Grand Total</td><td align='right' style='font-weight:bold;padding-left:20px;'>₹ " + input.Total_Price + "</td></tr>";
											// Final bottom accent line
											ticket_html = ticket_html + "<tr><td colspan='2' style='border-bottom:1px solid #333;padding-top:10px;'></td></tr></table></td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table></body></html>";
											// Update the Notes Field
											input.Estimation_Models = ticket_html;
										}
										else if(input.Estimation_Type == "Standard")
										{
											ticket_html = "";
											ticket_html = ticket_html + "<html>";
											ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Invoice</title></head>";
											ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
											ticket_html = ticket_html + "<table width='800' style='background:#ffffff;border:1px solid #999;border-collapse:collapse;'>";
											// --- TOP HEADER (Logo & Title) ---
											ticket_html = ticket_html + "<tr>";
											// --- LEFT BOX: Estimation & Admin ---
											ticket_html = ticket_html + "<td width='50%' style='padding:15px; border:1px solid #999; vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0; color:#000; font-size:22px;'>Estimation" + " " + "From" + " " + input.Organization_Name + " </h3>";
											ticket_html = ticket_html + "<h5 style='margin:10px 0 0 0; color:#000; font-size:15px; font-weight:300;'>by Admin " + input.Admin_Name + "</h5>";
											ticket_html = ticket_html + "</td>";
											// Close Left Cell
											// --- RIGHT BOX: Organization Address ---
											ticket_html = ticket_html + "<td width='50%' align='right' style='padding:15px; border:1px solid #999; vertical-align:top;'>";
											ticket_html = ticket_html + "<h4 style='margin:0; font-size:18px; font-weight:bold;'>Company Address</h4>";
											ticket_html = ticket_html + "<p style='margin:5px 0; font-size:12px; color:#333; line-height:1.5;'>" + input.Organization_Address + "</p>";
											ticket_html = ticket_html + "</td>";
											// Close Right Cell
											ticket_html = ticket_html + "</tr>";
											// --- INVOICE DETAILS GRID ---
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:0;border:1px solid #999;'><table width='100%' cellspacing='0' style='font-size:11px;'>";
											// 	ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;width:100px;'>#</td><td>: INV-000001</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;'>Date :" + "</td><td>:" + " " + zoho.currenttime + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;'>Terms :</td><td>:Due on Receipt</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;'>Due Date :</td><td>:" + " " + zoho.currenttime + "</td></tr></table></td>";
											ticket_html = ticket_html + "<td style='border:1px solid #999;'>&nbsp;</td></tr>";
											// --- BILLING & SHIPPING COLUMNS ---
											ticket_html = ticket_html + "<tr style='background:#f9f9f9;font-size:12px;'>";
											ticket_html = ticket_html + "<td style='padding:5px 8px;border:1px solid #999;font-weight:bold;'>Bill From</td>";
											ticket_html = ticket_html + "<td style='padding:5px 8px;border:1px solid #999;font-weight:bold;'>Bill To</td></tr>";
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:8px;border:1px solid #999;font-size:11px;vertical-align:top;'><br>" + input.Organization_Address + "</td>";
											ticket_html = ticket_html + "<td style='padding:8px;border:1px solid #999;font-size:11px;vertical-align:top;'><br>" + input.Customer_Address + "</td></tr>";
											// --- ITEM TABLE HEADER ---
											ticket_html = ticket_html + "<tr><td colspan='2' style='padding:0;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' style='border-collapse:collapse;font-size:11px;'>";
											ticket_html = ticket_html + "<tr style='background:#f5f5f5;text-align:center;'>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:30px;'>#</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;text-align:left;'>Item & Description</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:60px;'>Qty</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:80px;'>Tax (in %)</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:80px;'>Tax amount</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:80px;'>Amount</td></tr>";
											// --- ITEM LINE ---
											ticket_html = ticket_html + "<tr>";
											//insert the value in row in estimation ... use the below line code 
											ticket_html = ticket_html + "<td align='center' style='padding:10px 5px;border:1px solid #999;'></td>";
											ticket_html = ticket_html + "<td style='padding:10px 5px;border:1px solid #999;'>" + input.Service_Name + "</td>";
											ticket_html = ticket_html + "<td align='center' style='padding:10px 5px;border:1px solid #999;'>1.00<br><span style='font-size:9px;color:#666;'>" + "-" + "</span></td>";
											ticket_html = ticket_html + "<td align='right' style='padding:10px 5px;border:1px solid #999;'>" + input.Tax_Percentage + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:10px 5px;border:1px solid #999;'>" + input.Tax_Amount + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:10px 5px;border:1px solid #999;'>" + input.Price_For_The_Service + "</td></tr>";
											// --- EMPTY SPACE TO FILL PAGE ---
											ticket_html = ticket_html + "<tr><td colspan='2' style='height:250px;border:1px solid #999;'>&nbsp;</td><td style='border:1px solid #999;'>&nbsp;</td><td style='border:1px solid #999;'>&nbsp;</td><td style='border:1px solid #999;'>&nbsp;</td></tr>";
											ticket_html = ticket_html + "</table></td></tr>";
											// --- TOTALS & FOOTER ---
											ticket_html = ticket_html + "<tr><td style='padding:15px;border:1px solid #999;vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-size:11px;color:#555;'>Total In Words</p>";
											// 	ticket_html = ticket_html + "<p style='margin:2px 0;font-size:11px;font-style:italic;font-weight:bold;'>Indian Rupee " + input.Total_Price = thisapp.Num2Words(input.Total_Price)
											//  + " Only</p>";
											ticket_html = ticket_html + "<p style='margin:15px 0 0 0;font-size:11px;font-weight:bold;'>Notes</p>";
											ticket_html = ticket_html + "<p style='margin:2px 0;font-size:11px;'>Thanks for your business.</p></td>";
											ticket_html = ticket_html + "<td style='padding:0;border:1px solid #999;vertical-align:top;'><table width='100%' cellspacing='0' style='font-size:11px;'>";
											ticket_html = ticket_html + "<tr><td align='right' style='padding:5px;border-bottom:1px solid #eee;'>Sub Total</td><td align='right' style='padding:5px;width:80px;'>" + input.Tax_Amount + "</td></tr>";
											ticket_html = ticket_html + "<tr><td align='right' style='padding:5px;border-bottom:1px solid #eee;font-weight:bold;'>Total</td><td align='right' style='padding:5px;font-weight:bold;'>₹" + input.Total_Price + "</td></tr>";
											// 	ticket_html = ticket_html + "<tr><td align='right' style='padding:5px;font-weight:bold;'>Total Services</td><td align='right' style='padding:5px;font-weight:bold;'>" + input.Service_Name + "</td></tr>";
											ticket_html = ticket_html + "<tr><td colspan='2' align='center' style='padding-top:80px;'><div style='border-top:1px solid #999;width:150px;margin:0 auto;'></div><p style='font-size:10px;margin-top:5px;'>Authorized Signature</p></td></tr></table></td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table></body></html>";
											input.Estimation_Models = ticket_html;
										}
										else if(input.Estimation_Type == "Premium")
										{
											ticket_html = "";
											ticket_html = ticket_html + "<html>";
											ticket_html = ticket_html + "<head><meta charset='UTF-8'></head>";
											ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
											ticket_html = ticket_html + "<table width='750' style='background:#ffffff;padding:0;border:1px solid #ddd;'>";
											// --- BLUE TOP HEADER (Fixed: Added closing </td>) ---
											ticket_html = ticket_html + "<tr><td style='background:#6281c2;padding:30px;color:#ffffff;'>";
											ticket_html = ticket_html + "<table width='100%'><tr>";
											ticket_html = ticket_html + "<td style='vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0;font-size:18px;'>" + input.Organization_Name + "</h3>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;line-height:1.5;'>" + input.Organization_Address + "</p></td>";
											ticket_html = ticket_html + "<td align='right' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0;font-size:18px;'>Estimation</h3>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;line-height:1.5;'>" + "By " + "Admin " + input.Admin_Name + "</p></td>";
											//use the below row to insert a data in estimation
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:14px;'></p></td>";
											ticket_html = ticket_html + "</tr></table>";
											ticket_html = ticket_html + "</td></tr>";
											// THIS WAS MISSING - Closes the blue section
											// --- ADDRESS SECTION (Now white background) ---
											ticket_html = ticket_html + "<tr><td style='padding:30px;'><table width='100%'><tr>";
											ticket_html = ticket_html + "<td width='50%' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;color:#333;'>Service Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#555;line-height:1.4;'>" + input.Customer_Address + "</p></td>";
											ticket_html = ticket_html + "<td width='50%' align='right' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;color:#333;'>Billing Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#555;line-height:1.4;'>" + input.Customer_Address + "</p></td></tr></table>";
											// --- SUMMARY ---
											ticket_html = ticket_html + "<div style='margin-top:25px;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Summary</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;'>" + input.Description + "</p></div>";
											// --- ITEM TABLE ---
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' style='margin-top:20px;border-top:2px solid #333;'>";
											ticket_html = ticket_html + "<tr style='color:#6281c2;font-size:12px;'>";
											ticket_html = ticket_html + "<th align='left' style='padding:10px 0;'>Service & Part</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:10px 0;'>Tax (in %)</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:10px 0;'>Tax Amount</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:10px 0;'>Line Item Amount</th></tr>";
											ticket_html = ticket_html + "<tr><td colspan='4' style='border-bottom:1px solid #333;'></td></tr>";
											// Item Row (Fixed: Mapping price/amount to the correct variables)
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:15px 0;font-size:12px;'><strong>Repair service</strong><br><span style='color:#777;'>" + input.Service_Name + "</span></td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 0;font-size:12px;'>" + input.Tax_Percentage + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 0;font-size:12px;'>₹ " + input.Tax_Amount + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 0;font-size:12px;'>₹ " + input.Total_Price + "</td></tr></table>";
											// --- TOTALS SECTION ---
											ticket_html = ticket_html + "<table width='100%'><tr><td width='60%'></td>";
											ticket_html = ticket_html + "<td width='40%' style='background:#f9fbfd;padding:15px;'>";
											ticket_html = ticket_html + "<table width='100%' style='font-size:12px;line-height:2;'>";
											ticket_html = ticket_html + "<tr><td align='right' style='color:#555;'>Sub Total</td><td align='right'>₹ " + input.Tax_Amount + "</td></tr>";
											ticket_html = ticket_html + "<tr><td align='right' style='font-weight:bold;border-top:1px solid #ddd;padding-top:5px;'>Grand Total</td><td align='right' style='font-weight:bold;border-top:1px solid #ddd;padding-top:5px;'>₹ " + input.Total_Price + "</td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table>";
											// --- TERMS ---
											ticket_html = ticket_html + "<div style='margin-top:30px;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Terms and Conditions</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;'>This is a preliminary estimate. Final charges may vary depending on actual service requirements. Customer approval is required before execution.</p></div>";
											ticket_html = ticket_html + "</td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table></body></html>";
											input.Estimation_Models = ticket_html;
										}
										else
										{
											input.Estimation_Models = null;
										}
						)
					}
				}

			}
			Fetch_Customer_Data as "Fetch Customer Data"
			{
				type =  form
				form = Estimations

				record event = on add or edit

				on user input of Customer_Phone_Number
				{
					actions 
					{
						custom deluge script
						(
											var = Customer_Request[Phone_Number == input.Customer_Phone_Number];
										if(var.count() > 0)
										{
											input.Customer_Name = var.Name;
											input.Customer_Address = var.Service_Address;
											input.Service_Name = var.Service_By_Organization.Name_Of_The_Service;
											input.Customer_Email = var.Email;
										}
										else
										{
											input.Customer_Name = null;
											input.Customer_Address = null;
											input.Service_Name = null;
											input.Customer_Email = null;
										}
						)
					}
				}

			}
			Fetch_Organization_Data as "Fetch Organization Data"
			{
				type =  form
				form = Estimations

				record event = on add or edit

				on user input of Customer_Phone_Number
				{
					actions 
					{
						custom deluge script
						(
											var = Add_Organization[Company_Address != null];
										if(var.count() > 0)
										{
											input.Organization_Address = var.Company_Address;
											input.Admin_Name = var.Admin_Name;
											input.Organization_Name = var.Company_Name;
										}
										else
										{
											input.Organization_Address = null;
											input.Admin_Name = null;
											input.Organization_Name = null;
										}
						)
					}
				}

			}
			Fetch_Price_Data as "Fetch Price Data"
			{
				type =  form
				form = Estimations

				record event = on add or edit

				on user input of Customer_Phone_Number
				{
					actions 
					{
						custom deluge script
						(
											var = Service_By_Organization[Price != null];
										if(var.count() > 0)
										{
											input.Service_Name = var.Name_Of_The_Service;
											input.Price_For_The_Service = var.Price;
											input.Tax_Percentage = var.Tax_Percentage;
										}
										else
										{
											input.Service_Name = null;
											input.Price_For_The_Service = null;
											input.Tax_Percentage = null;
										}
										var = Service_By_Organization[Name_Of_The_Service != null];
										if(var.count() > 0)
										{
											tax_per = input.Tax_Percentage.toNumber() / 100;
											mul = tax_per * input.Price_For_The_Service;
											input.Tax_Amount = mul;
											info "Yes";
											input.Total_Price = input.Price_For_The_Service + input.Tax_Amount;
										}
										else
										{
											input.Tax_Amount = null;
											info "No";
											input.Total_Price = null;
										}
						)
					}
				}

			}
			Cal_Tax_Amount as "Cal Tax Amount"
			{
				type =  form
				form = Estimations

				record event = on add or edit
					status = inactive

				on user input of Tax_Amount
				{
					actions 
					{
						custom deluge script
						(
											var = Service_By_Organization[Name_Of_The_Service != null];
										if(var.count() > 0)
										{
											tax_per = input.Tax_Percentage.toNumber() / 100;
											mul = tax_per.toNumber() * input.Price_For_The_Service;
											input.Tax_Amount = mul;
										}
										else
										{
											input.Tax_Amount = null;
										}
						)
					}
				}

			}
			Send_Estimation_To_Techni as "Send Estimation To Technician"
			{
				type =  form
				form = Estimations

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											// send estimation to customer
										intro = "Dear Customer ! You service request for " + input.Service_Name + " confirmed, Please find the estimation and download below. <br><br><b>Regards</b>" + "<br>" + input.Organization_Name;
										if(input.Estimation_Type == "Normal")
										{
											ticket_html = "";
											ticket_html = ticket_html + "<html>";
											ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Estimation</title></head>";
											ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
											ticket_html = ticket_html + "<table width='750' style='background:#ffffff;padding:40px;border:1px solid #ddd;'>";
											// --- TOP HEADER ---
											ticket_html = ticket_html + "<tr><td><table width='100%'><tr><td style='vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0;color:#000;font-size:20px;'>Estimation" + " " + "From" + " " + input.Organization_Name;
											ticket_html = ticket_html + "<h5 style='margin:0;color:#000;font-size:15px;font-weight:300;'>" + " " + "by" + " " + "Admin" + " " + input.Admin_Name + "</h5>";
											ticket_html = ticket_html + "<h6 style='margin:0;color:#000;font-size:15px;font-weight:300;'>" + " " + input.Organization_Address + "<h6>";
											ticket_html = ticket_html + "</td></tr></table>";
											// --- ADDRESS SECTION ---
											ticket_html = ticket_html + "<tr><td style='padding-top:40px;'><table width='100%'><tr><td width='50%' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Service Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#333;line-height:1.5;'>" + input.Customer_Address + "</p></td>";
											ticket_html = ticket_html + "<td width='50%' align='right' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Billing Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#333;line-height:1.5;'>" + input.Customer_Address + "<br>Zentegra<br>Bengaluru, Karnataka</p></td></tr></table></td></tr>";
											// --- SERVICE TABLE (Black Header Bar) ---
											ticket_html = ticket_html + "<tr><td style='padding-top:30px;'><table width='100%' cellspacing='0' style='border-collapse:collapse;'>";
											// The black box row - padding increased to 12px for better thickness
											ticket_html = ticket_html + "<tr style='background:#111;color:#fff;'>";
											ticket_html = ticket_html + "<th align='left' style='padding:12px 10px;font-size:12px;'>Service & Part</th>";
											ticket_html = ticket_html + "<th align='left' style='padding:12px 10px;font-size:12px;'>Tax (in %)</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:12px 10px;font-size:12px;'>Tax Amount</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:12px 10px;font-size:12px;'>Line Item Amount</th></tr>";
											// Item Data Row - Fixed to exactly 3 columns to match the header
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:15px 10px;font-size:13px;'><strong>" + input.Service_Name + "</strong></td>";
											ticket_html = ticket_html + "<td style='padding:15px 10px;font-size:13px;'><strong>" + input.Tax_Percentage + "</strong></td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 10px;font-size:13px;'>" + input.Tax_Amount + "</td>";
											// List price left blank as per template
											ticket_html = ticket_html + "<td align='right' style='padding:15px 10px;font-size:13px;'>" + input.Total_Price + "</td></tr>";
											// Bottom border after the items
											ticket_html = ticket_html + "<tr><td colspan='4' style='border-bottom:1px solid #000;'></td></tr></table></td></tr>";
											// --- TOTALS --- 
											ticket_html = ticket_html + "<tr><td align='right' style='padding-top:20px;'><table width='250' style='font-size:13px;line-height:2;'>";
											ticket_html = ticket_html + "<tr><td align='right' style='color:#555;'>Tax Total</td><td align='right' style='padding-left:20px;'>₹ " + input.Tax_Amount + "</td></tr>";
											ticket_html = ticket_html + "<tr><td align='right' style='font-weight:bold;'>Grand Total</td><td align='right' style='font-weight:bold;padding-left:20px;'>₹ " + input.Total_Price + "</td></tr>";
											// Final bottom accent line
											ticket_html = ticket_html + "<tr><td colspan='2' style='border-bottom:1px solid #333;padding-top:10px;'></td></tr></table></td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table></body></html>";
											// Update the Notes Field
											//convert to pdf 
											pdfFile = zoho.file.convertToPDF(ticket_html);
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Customer_Email
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"Normal Estimation for your service request"
												message :intro
												Attachments :file:pdfFile
											]
										}
										else if(input.Estimation_Type == "Standard")
										{
											ticket_html = "";
											ticket_html = ticket_html + "<html>";
											ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Invoice</title></head>";
											ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
											ticket_html = ticket_html + "<table width='800' style='background:#ffffff;border:1px solid #999;border-collapse:collapse;'>";
											// --- TOP HEADER (Logo & Title) ---
											ticket_html = ticket_html + "<tr>";
											// --- LEFT BOX: Estimation & Admin ---
											ticket_html = ticket_html + "<td width='50%' style='padding:15px; border:1px solid #999; vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0; color:#000; font-size:22px;'>Estimation" + " " + "From" + " " + input.Organization_Name + " </h3>";
											ticket_html = ticket_html + "<h5 style='margin:10px 0 0 0; color:#000; font-size:15px; font-weight:300;'>by Admin " + input.Admin_Name + "</h5>";
											ticket_html = ticket_html + "</td>";
											// Close Left Cell
											// --- RIGHT BOX: Organization Address ---
											ticket_html = ticket_html + "<td width='50%' align='right' style='padding:15px; border:1px solid #999; vertical-align:top;'>";
											ticket_html = ticket_html + "<h4 style='margin:0; font-size:18px; font-weight:bold;'>Company Address</h4>";
											ticket_html = ticket_html + "<p style='margin:5px 0; font-size:12px; color:#333; line-height:1.5;'>" + input.Organization_Address + "</p>";
											ticket_html = ticket_html + "</td>";
											// Close Right Cell
											ticket_html = ticket_html + "</tr>";
											// --- INVOICE DETAILS GRID ---
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:0;border:1px solid #999;'><table width='100%' cellspacing='0' style='font-size:11px;'>";
											// 	ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;width:100px;'>#</td><td>: INV-000001</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;'>Date :" + "</td><td>:" + " " + zoho.currenttime + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;'>Terms :</td><td>:Due on Receipt</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:3px 8px;font-weight:bold;'>Due Date :</td><td>:" + " " + zoho.currenttime + "</td></tr></table></td>";
											ticket_html = ticket_html + "<td style='border:1px solid #999;'>&nbsp;</td></tr>";
											// --- BILLING & SHIPPING COLUMNS ---
											ticket_html = ticket_html + "<tr style='background:#f9f9f9;font-size:12px;'>";
											ticket_html = ticket_html + "<td style='padding:5px 8px;border:1px solid #999;font-weight:bold;'>Bill From</td>";
											ticket_html = ticket_html + "<td style='padding:5px 8px;border:1px solid #999;font-weight:bold;'>Bill To</td></tr>";
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:8px;border:1px solid #999;font-size:11px;vertical-align:top;'><br>" + input.Organization_Address + "</td>";
											ticket_html = ticket_html + "<td style='padding:8px;border:1px solid #999;font-size:11px;vertical-align:top;'><br>" + input.Customer_Address + "</td></tr>";
											// --- ITEM TABLE HEADER ---
											ticket_html = ticket_html + "<tr><td colspan='2' style='padding:0;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' style='border-collapse:collapse;font-size:11px;'>";
											ticket_html = ticket_html + "<tr style='background:#f5f5f5;text-align:center;'>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:30px;'>#</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;text-align:left;'>Item & Description</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:60px;'>Qty</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:80px;'>Tax (in %)</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:80px;'>Tax amount</td>";
											ticket_html = ticket_html + "<td style='padding:5px;border:1px solid #999;width:80px;'>Amount</td></tr>";
											// --- ITEM LINE ---
											ticket_html = ticket_html + "<tr>";
											//insert the value in row in estimation ... use the below line code 
											ticket_html = ticket_html + "<td align='center' style='padding:10px 5px;border:1px solid #999;'></td>";
											ticket_html = ticket_html + "<td style='padding:10px 5px;border:1px solid #999;'>" + input.Service_Name + "</td>";
											ticket_html = ticket_html + "<td align='center' style='padding:10px 5px;border:1px solid #999;'>1.00<br><span style='font-size:9px;color:#666;'>" + "-" + "</span></td>";
											ticket_html = ticket_html + "<td align='right' style='padding:10px 5px;border:1px solid #999;'>" + input.Tax_Percentage + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:10px 5px;border:1px solid #999;'>" + input.Tax_Amount + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:10px 5px;border:1px solid #999;'>" + input.Price_For_The_Service + "</td></tr>";
											// --- EMPTY SPACE TO FILL PAGE ---
											ticket_html = ticket_html + "<tr><td colspan='2' style='height:250px;border:1px solid #999;'>&nbsp;</td><td style='border:1px solid #999;'>&nbsp;</td><td style='border:1px solid #999;'>&nbsp;</td><td style='border:1px solid #999;'>&nbsp;</td></tr>";
											ticket_html = ticket_html + "</table></td></tr>";
											// --- TOTALS & FOOTER ---
											ticket_html = ticket_html + "<tr><td style='padding:15px;border:1px solid #999;vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-size:11px;color:#555;'>Total In Words</p>";
											// 	ticket_html = ticket_html + "<p style='margin:2px 0;font-size:11px;font-style:italic;font-weight:bold;'>Indian Rupee " + input.Total_Price = thisapp.Num2Words(input.Total_Price)
											//  + " Only</p>";
											ticket_html = ticket_html + "<p style='margin:15px 0 0 0;font-size:11px;font-weight:bold;'>Notes</p>";
											ticket_html = ticket_html + "<p style='margin:2px 0;font-size:11px;'>Thanks for your business.</p></td>";
											ticket_html = ticket_html + "<td style='padding:0;border:1px solid #999;vertical-align:top;'><table width='100%' cellspacing='0' style='font-size:11px;'>";
											ticket_html = ticket_html + "<tr><td align='right' style='padding:5px;border-bottom:1px solid #eee;'>Sub Total</td><td align='right' style='padding:5px;width:80px;'>" + input.Tax_Amount + "</td></tr>";
											ticket_html = ticket_html + "<tr><td align='right' style='padding:5px;border-bottom:1px solid #eee;font-weight:bold;'>Total</td><td align='right' style='padding:5px;font-weight:bold;'>₹" + input.Total_Price + "</td></tr>";
											// 	ticket_html = ticket_html + "<tr><td align='right' style='padding:5px;font-weight:bold;'>Total Services</td><td align='right' style='padding:5px;font-weight:bold;'>" + input.Service_Name + "</td></tr>";
											ticket_html = ticket_html + "<tr><td colspan='2' align='center' style='padding-top:80px;'><div style='border-top:1px solid #999;width:150px;margin:0 auto;'></div><p style='font-size:10px;margin-top:5px;'>Authorized Signature</p>" + "</td></tr></table></td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table></body></html>";
											pdfFile = zoho.file.convertToPDF(ticket_html);
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Customer_Email
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"Standard Estimation for your service request"
												message :intro
												Attachments :file:pdfFile
											]
										}
										else if(input.Estimation_Type == "Premium")
										{
											ticket_html = "";
											ticket_html = ticket_html + "<html>";
											ticket_html = ticket_html + "<head><meta charset='UTF-8'></head>";
											ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
											ticket_html = ticket_html + "<table width='750' style='background:#ffffff;padding:0;border:1px solid #ddd;'>";
											// --- BLUE TOP HEADER (Fixed: Added closing </td>) ---
											ticket_html = ticket_html + "<tr><td style='background:#6281c2;padding:30px;color:#ffffff;'>";
											ticket_html = ticket_html + "<table width='100%'><tr>";
											ticket_html = ticket_html + "<td style='vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0;font-size:18px;'>" + input.Organization_Name + "</h3>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;line-height:1.5;'>" + input.Organization_Address + "</p></td>";
											ticket_html = ticket_html + "<td align='right' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<h3 style='margin:0;font-size:18px;'>Estimation</h3>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;line-height:1.5;'>" + "By " + "Admin " + input.Admin_Name + "</p></td>";
											//use the below row to insert a data in estimation
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:14px;'></p></td>";
											ticket_html = ticket_html + "</tr></table>";
											ticket_html = ticket_html + "</td></tr>";
											// THIS WAS MISSING - Closes the blue section
											// --- ADDRESS SECTION (Now white background) ---
											ticket_html = ticket_html + "<tr><td style='padding:30px;'><table width='100%'><tr>";
											ticket_html = ticket_html + "<td width='50%' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;color:#333;'>Service Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#555;line-height:1.4;'>" + input.Customer_Address + "</p></td>";
											ticket_html = ticket_html + "<td width='50%' align='right' style='vertical-align:top;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;color:#333;'>Billing Address</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;color:#555;line-height:1.4;'>" + input.Customer_Address + "</p></td></tr></table>";
											// --- SUMMARY ---
											ticket_html = ticket_html + "<div style='margin-top:25px;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Summary</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;'>" + input.Description + "</p></div>";
											// --- ITEM TABLE ---
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' style='margin-top:20px;border-top:2px solid #333;'>";
											ticket_html = ticket_html + "<tr style='color:#6281c2;font-size:12px;'>";
											ticket_html = ticket_html + "<th align='left' style='padding:10px 0;'>Service & Part</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:10px 0;'>Tax (in %)</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:10px 0;'>Tax Amount</th>";
											ticket_html = ticket_html + "<th align='right' style='padding:10px 0;'>Line Item Amount</th></tr>";
											ticket_html = ticket_html + "<tr><td colspan='4' style='border-bottom:1px solid #333;'></td></tr>";
											// Item Row (Fixed: Mapping price/amount to the correct variables)
											ticket_html = ticket_html + "<tr>";
											ticket_html = ticket_html + "<td style='padding:15px 0;font-size:12px;'><strong>Repair service</strong><br><span style='color:#777;'>" + input.Service_Name + "</span></td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 0;font-size:12px;'>" + input.Tax_Percentage + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 0;font-size:12px;'>₹ " + input.Tax_Amount + "</td>";
											ticket_html = ticket_html + "<td align='right' style='padding:15px 0;font-size:12px;'>₹ " + input.Total_Price + "</td></tr></table>";
											// --- TOTALS SECTION ---
											ticket_html = ticket_html + "<table width='100%'><tr><td width='60%'></td>";
											ticket_html = ticket_html + "<td width='40%' style='background:#f9fbfd;padding:15px;'>";
											ticket_html = ticket_html + "<table width='100%' style='font-size:12px;line-height:2;'>";
											ticket_html = ticket_html + "<tr><td align='right' style='color:#555;'>Sub Total</td><td align='right'>₹ " + input.Tax_Amount + "</td></tr>";
											ticket_html = ticket_html + "<tr><td align='right' style='font-weight:bold;border-top:1px solid #ddd;padding-top:5px;'>Grand Total</td><td align='right' style='font-weight:bold;border-top:1px solid #ddd;padding-top:5px;'>₹ " + input.Total_Price + "</td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table>";
											// --- TERMS ---
											ticket_html = ticket_html + "<div style='margin-top:30px;'>";
											ticket_html = ticket_html + "<p style='margin:0;font-weight:bold;font-size:13px;'>Terms and Conditions</p>";
											ticket_html = ticket_html + "<p style='margin:5px 0;font-size:12px;'>This is a preliminary estimate. Final charges may vary depending on actual service requirements. Customer approval is required before execution.</p></div>";
											ticket_html = ticket_html + "</td></tr>";
											ticket_html = ticket_html + "</table></td></tr></table></body></html>";
											pdfFile = zoho.file.convertToPDF(ticket_html);
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Customer_Email
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"Premium Estimation for your service request"
												message :intro
												Attachments :file:pdfFile
											]
										}
						)
					}
				}

			}
			Fetch_Data_From_Admin as "Fetch Data From Admin"
			{
				type =  form
				form = Field_Technician

				record event = on add or edit
					status = inactive

				on user input of Customer_Phone_Number
				{
					actions 
					{
						custom deluge script
						(
											ad = Add_Organization[Payment_Types_Received_From_Organization == input.Payment_Type];
										if(ad.count() > 0)
										{
											input.Organization_Name = ad.Company_Name;
											input.Organization_Phone = ad.Phone_Number1;
											input.Organization_Address = ad.Company_Address;
											input.Organization_Website = ad.Website;
											info "Yes";
										}
										else
										{
											input.Organization_Name = null;
											input.Organization_Phone = null;
											input.Organization_Address = null;
											input.Organization_Website = null;
											info "No";
										}
						)
					}
				}

			}
			Payment_Recepit as "Payment Recepit"
			{
				type =  form
				form = Field_Technician

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Payment_Type == "UPI Payment" || input.Payment_Type == "Cash Payment" || input.Payment_Type == "Debit Card Payment")
										{
											// Container for Thermal Receipt style
											payment_html = "<html><body style='background-color:#f2f2f2; padding:20px; font-family:\"Courier New\", Courier, monospace; color:#000;'>";
											payment_html = payment_html + "<div style='width:320px; background:white; padding:20px; margin:auto; box-shadow:0 0 10px rgba(0,0,0,0.1); text-align:center;'>";
											// --- SHOP HEADER ---
											payment_html = payment_html + "<h3 style='margin:0; text-transform:uppercase; letter-spacing:2px;'>" + input.Organization_Name + "</h3>";
											payment_html = payment_html + "<p style='font-size:11px; margin:5px 0;'>" + input.Organization_Address + "<br>CONTACT NO: " + input.Organization_Phone + "</p>";
											payment_html = payment_html + "<p style='margin:5px 0;'>--------------------------------</p>";
											payment_html = payment_html + "<h3 style='margin:5px 0; text-transform:uppercase;'>CASH RECEIPT</h3>";
											payment_html = payment_html + "<p style='margin:5px 0;'>--------------------------------</p>";
											// --- INFO SECTION ---
											payment_html = payment_html + "<table width='100%' style='font-size:12px; text-align:left;'>";
											payment_html = payment_html + "<tr><td><b>DATE:</b> " + zoho.currentdate.toString("MM/dd/yy") + "</td><td align='right'><b>TIME:</b> " + zoho.currenttime.toString("HH:mm") + "</td></tr>";
											payment_html = payment_html + "<tr><td colspan='2'><b>CASHIER:</b> " + zoho.loginuser + "</td></tr>";
											payment_html = payment_html + "</table>";
											payment_html = payment_html + "<p style='margin:10px 0;'>--------------------------------</p>";
											// --- ITEMS SECTION ---
											payment_html = payment_html + "<table width='100%' style='font-size:13px; border-collapse:collapse;'>";
											payment_html = payment_html + "<tr><th align='left'>DESCRIPTION</th><th align='right'>PRICE</th></tr>";
											// Item Row
											payment_html = payment_html + "<tr><td style='padding:1px 0; text-align:left;'>" + input.Type_Of_Service + "</td><td align='right'>" + ifnull(input.Total_Amount,"0.00") + "</td></tr>";
											payment_html = payment_html + "</table>";
											payment_html = payment_html + "<p style='margin:10px 0;'>--------------------------------</p>";
											// --- TOTAL SECTION ---
											payment_html = payment_html + "<table width='100%' style='font-size:14px; font-weight:bold; text-align:left;'>";
											payment_html = payment_html + "<tr><td>TOTAL</td><td align='right'>₹" + ifnull(input.Total_Amount,"0.00") + "</td></tr>";
											payment_html = payment_html + "<tr><td style='font-size:12px; font-weight:normal;'>Payment Type: " + input.Payment_Type + "</td><td align='right' style='font-size:12px; font-weight:normal;'>Paid</td></tr>";
											payment_html = payment_html + "</table>";
											payment_html = payment_html + "<p style='margin:10px 0;'>--------------------------------</p>";
											// --- FOOTER ---
											// Simple CSS Barcode representation
											payment_html = payment_html + "<tr>" + "<td style='padding:10px;color:#555; text-align:left;'>QR code</td>" + "<td style='padding:10px;color:#27ae60;font-weight:bold; text-align:right;'>" + "<img src='https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=" + input.Total_Amount + "'style='width:90px;height:90px;'>" + "</td>" + "</tr>";
											payment_html = payment_html + "<div style='font-size:10px; margin-top:5px;'>ID: " + input.Service_ID + "</div>";
											payment_html = payment_html + "<h3 style='margin:20px 0 10px 0;'>THANK YOU!</h3>";
											payment_html = payment_html + "</div></body></html>";
											pdfFile1 = zoho.file.convertToPDF(payment_html);
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Customer_Email
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"Payment receipt"
												message :"Congratulations ! Your online payment was successfull, Please find the payment confirmation receipt below." + payment_html
												Attachments :file:pdfFile1
											]
										}
						)
					}
				}

			}
