			Invoice_Generating_To_Cus as "Invoice Generating To Customer"
			{
				type =  form
				form = Field_Technician

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											ticket_html = "";
										ticket_html = ticket_html + "<html>";
										ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Snacks invoice</title></head>";
										ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
										ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
										ticket_html = ticket_html + "<table width='600' style='background:#ffffff;border-radius:10px;padding:25px;'>";
										ticket_html = ticket_html + "<tr><td style='text-align:center;border-bottom:2px dashed #ddd;padding-bottom:15px;'>";
										ticket_html = ticket_html + "<h2 style='margin:0;color:#2c3e50;'>" + input.Organization_Name + "</h2>";
										ticket_html = ticket_html + "<p style='color:#777;font-size:10px;'>" + input.Organization_Address + "</p>";
										ticket_html = ticket_html + "<p style='color:#777;font-size:10px;'>" + input.Organization_Phone + "</p>";
										ticket_html = ticket_html + "<p style='color:#777;font-size:14px;'>Thank you for choosing our service !</p>";
										ticket_html = ticket_html + "<img src='https://w7.pngwing.com/pngs/949/49/png-transparent-check-mark-computer-icons-symbol-green-fruit-miscellaneous-text-logo-thumbnail.png' style='width:25px; vertical-align:middle; margin-right:8px;'>";
										// ticket_html = ticket_html + "<span style='background:#27ae60;color:#fff;padding:6px 14px;border-radius:20px;font-size:12px;'>PAID ✅</span>";
										ticket_html = ticket_html + "</td></tr>";
										// Start the Box Container
										ticket_html = ticket_html + "<tr><td>";
										// ticket_html = ticket_html + "<div style='border: 2px solid #ddd; border-radius: 10px; padding: 20px; background-color: #ffffff; box-shadow: 2px 2px 10px rgba(0,0,0,0.1);'>";
										// Your Table inside the Box
										ticket_html = ticket_html + "<table width='100%' style='font-size:14px; border-collapse: collapse;'>";
										// Header Row (Optional - Looks nice in a box)
										ticket_html = ticket_html + "<tr><td colspan='2' style='padding:10px; border-bottom:1px solid #eee; text-align: center; font-size:13px; font-weight:bold; color: #42464a;'>Service Summary</td></tr>";
										// Data Rows - Fixed Labels
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555; font-weight:bold;'>Customer Name</td><td style='padding:10px;'>" + ifnull(input.Customer_Name,"") + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555; font-weight:bold;'>Phone Number</td><td style='padding:10px;'>" + ifnull(input.Customer_Phone_Number,"") + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555; font-weight:bold;'>Email Address</td><td style='padding:10px;'>" + ifnull(input.Customer_Email,"") + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555; font-weight:bold;'>Address</td><td style='padding:10px;'>" + ifnull(input.Service_Address,"") + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555; font-weight:bold;'>Service Type</td><td style='padding:10px;'>" + ifnull(input.Type_Of_Service,"") + "</td></tr>";
										// Price Section with a small divider
										ticket_html = ticket_html + "<tr><td colspan='2'><hr style='border:0; border-top:1px dashed #ccc;'></td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;font-weight:bold;'>Service Price</td><td style='padding:10px;'>₹" + input.Service_Price + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;font-weight:bold;'>Travel Charge</td><td style='padding:10px;'>₹" + input.Travel_Charge + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;font-weight:bold;'>Material Cost</td><td style='padding:10px;'>₹" + input.Material_Cost + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;font-weight:bold;'>Tax Amount(" + input.Tax_Percentage + "%)</td><td style='padding:10px;'>₹" + input.Tax_Amount + "</td></tr>";
										// Total Amount Bold Row
										ticket_html = ticket_html + "<tr style='background-color:#8d72723a;'><td style='padding:10px; font-weight:bold; color:#2c3e50;'>Total Payable</td><td style='padding:10px; font-weight:bold; font-size:16px; color:#e74c3c;'>₹" + input.Total_Amount + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;font-weight:bold;'>Payment Type</td><td style='padding:10px;'>₹" + input.Payment_Type + "</td></tr>";
										// QR Code Section
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;font-weight:bold;'>Payment QR</td><td style='padding:10px;'>" + "<img src='https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=" + input.Total_Amount + "' style='width:90px;height:90px; border:1px solid #eee;'>" + "</td></tr>";
										// --- START OF FOOTER SECTION ---
										ticket_html = ticket_html + "<tr><td style='padding-top:25px;'>";
										ticket_html = ticket_html + "<table width='100%' style='border-top:1px solid #eee; padding-top:15px;'>";
										// 1. Phone Row
										ticket_html = ticket_html + "<tr><td style='padding:5px; vertical-align:middle;'>";
										ticket_html = ticket_html + "<table border='0' cellspacing='0' cellpadding='0'><tr>";
										ticket_html = ticket_html + "<td style='width:25px;'><img src='https://cdn-icons-png.flaticon.com/128/5585/5585846.png' style='width:14px; display:block;'></td>";
										ticket_html = ticket_html + "<td style='font-size:12px; color:#777; line-height:14px;'>+91-8608944648</td>";
										ticket_html = ticket_html + "</tr></table></td></tr>";
										// 2. Email Row
										ticket_html = ticket_html + "<tr><td style='padding:5px; vertical-align:middle;'>";
										ticket_html = ticket_html + "<table border='0' cellspacing='0' cellpadding='0'><tr>";
										ticket_html = ticket_html + "<td style='width:25px;'><img src='https://cdn-icons-png.flaticon.com/512/542/542689.png' style='width:14px; display:block;'></td>";
										ticket_html = ticket_html + "<td style='font-size:12px; color:#777; line-height:14px;'>admin@organization.com</td>";
										ticket_html = ticket_html + "</tr></table></td></tr>";
										// 3. Location Row
										ticket_html = ticket_html + "<tr><td style='padding:5px; vertical-align:middle;'>";
										ticket_html = ticket_html + "<table border='0' cellspacing='0' cellpadding='0'><tr>";
										ticket_html = ticket_html + "<td style='width:25px;'><img src='https://cdn-icons-png.flaticon.com/512/484/484167.png' style='width:14px; display:block;'></td>";
										ticket_html = ticket_html + "<td style='font-size:12px; color:#777; line-height:14px;'>Bengaluru, Karnataka, India</td>";
										ticket_html = ticket_html + "</tr></table></td></tr>";
										ticket_html = ticket_html + "</table></td></tr>";
										// Close the Box div
										ticket_html = ticket_html + "</td></tr>";
										ticket_html = ticket_html + "</body></html>";
										pdfFile1 = zoho.file.convertToPDF(ticket_html);
										//combining two messages to send in one message 
										// intro_text = "Dear Guest," + " " + input.Customer_name1 + " " + " <br><br> Your reservation is confirmed. Please find your ticket below:<br><br>"; 
										// final_message = intro_text + ticket_html; 
										// Send Mail Task 
										sendmail
										[
											from :"zentegrademo31@gmail.com"
											to :input.Customer_Email
											cc:"manikandansjobzen@gmail.com"
											reply to :"manikandan@zentegra.com"
											subject :"Invoice for your service"
											message :ticket_html
											Attachments :file:pdfFile1
										]
						)
					}
				}

			}
