			Notify_To_Admin_And_Field as "Notify To Admin And Field Technicial"
			{
				type =  form
				form = Reschedule_My_Service

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											msg = "*I want to reschedule my service*" + "\n" + "\n*Customer Name:* " + input.Name + "\n*Customer Mobile:* " + input.Phone_Number1 + "\n*Service Name:* " + input.Service_Name + "\n*Service ID:* " + input.Service_ID + "\n*Email Address:* " + input.Email + "\n*Reason for reschedule:* " + input.Reason_For_Rescheduling + "\n*Reschedule Date:* " + input.Reschedule_Date + "\n*Reschedule Time:* " + input.Reschedule_Time + "\n*Instructions:* " + input.Instructions + "\n*Service address:* " + input.Address + "\n*Previous preferred date:* " + input.Previous_Prefer_Date + "\n*Previous preferred time:* " + input.Previous_Prefer_Time;
										encodedMsg = zoho.encryption.urlEncode(msg);
										// 2. Clean the Mobile Number
										rawNum = ifnull(input.Service_man_phone_number,"").toString();
										cleanNumber = rawNum.replaceAll("[^0-9]","");
										// Take last 10 digits
										if(cleanNumber.length() > 10)
										{
											cleanNumber = cleanNumber.subString(cleanNumber.length() - 10);
										}
										// 3. Construct the final URL
										whatsappURL = "https://api.whatsapp.com/send?phone=91" + cleanNumber + "&text=" + encodedMsg;
										// 4. THE FINAL ACTION: Open WhatsApp immediately
										// This replaces 'show' and works perfectly in On Success
										openurl(whatsappURL,"new window");
										msgmail = "<b>Dear Customer,</b>" + "<br><br>Your service request has been successfully rescheduled." + " " + input.Service_Name + " " + "<br><b>Service adress:</b>" + " " + input.Address + " " + "<br><b>New Date:</b>" + " " + input.Reschedule_Date + " " + "<br><b>New Time:</b>" + " " + input.Reschedule_Time + "<br><b>Service ID:</b> " + " " + input.Service_ID + " " + "<br> Thank you for your cooperation." + "<br><br><b>Regards,</b>" + "<br>Admin from the Organization";
										sendmail
										[
											from :"zentegrademo31@gmail.com"
											to :input.Email
											reply to :"manikandan@zentegra.com"
											subject :"Your High priority service was cancelled."
											message :msgmail
										]
										//send mail to the admin
										msg1 = "<b>Admin,</b>" + "<br><br>Customer" + " " + input.Name + " " + "service request has been rescheduled" + " " + "<br><br><b>Name:</b>" + " " + input.Name + " " + "<br><b>Customer Phone Number:</b> " + input.Phone_Number1 + " " + "<br><b>Service selcted by customer:</b>" + input.Service_Name + " " + "<br><b>Service adress:</b>" + input.Address + " " + "<br><b>New Date:</b>" + " " + input.Reschedule_Date + " " + "<br><b>New Time:</b>" + " " + input.Reschedule_Time + "<br><b>Service ID:</b>" + input.Service_ID + "<br><br><b>Regards,</b>" + "<br>The order has been rescheduled by the customer. Kindly reach out to the customer if further clarification is required.";
										sendmail
										[
											from :"zentegrademo31@gmail.com"
											to :"manikandansjobzen@gmail.com"
											reply to :"manikandan@zentegra.com"
											subject :"High priority service cancelled by customer."
											message :msg1
										]
						)
					}
				}

			}
